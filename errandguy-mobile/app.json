{
  "expo": {
    "name": "ErrandGuy",
    "slug": "errandguy",
    "scheme": "errandguy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.errandguy.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ErrandGuy needs your location to find nearby runners and track deliveries.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "ErrandGuy uses your location in the background to update your position while on an active errand.",
        "NSCameraUsageDescription": "ErrandGuy needs camera access to take photos of items and delivery proofs.",
        "NSPhotoLibraryUsageDescription": "ErrandGuy needs photo library access to upload item photos.",
        "NSMicrophoneUsageDescription": "ErrandGuy needs microphone access for in-app calls."
      }
    },
    "android": {
      "package": "com.errandguy.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-location",
      "expo-camera",
      "expo-image-picker",
      "expo-notifications",
      "expo-font",
      "@rnmapbox/maps",
      "expo-image"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "1684a4bc-4b59-47f4-a87e-3b3262438098"
      },
      "router": {}
    },
    "updates": {
      "url": ""
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "clark123"
  }
}
